#######################################
# Print the first n Fibonacci numbers
#######################################

variable counter has_type Number is 1;

function fibRecursive(n has_type Number) has_type Number {
    write_to_console cast_to String (counter);
    counter is add (counter 1);
    if (n LESS 0 ) {
       return -1;
    }
    if (n LESS_EQUAL 1) {
        return n;
    }
    else {
        return add(fibRecursive(subtract(n 1))  fibRecursive (subtract(n 2)));
    }
}


# Input
variable n has_type Number is 10;
write_to_console cast_to String (fibIterative(n));
write_to_console cast_to String (fibRecursive(n));

